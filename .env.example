# Supabase — copy this file to .env.local and fill in your project values.
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key (NEVER expose to the browser). Used by trusted server actions
# such as creating a merchant during onboarding. Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the deployed app (QR links, SMS hub URLs, emails).
# Prefer APP_URL. NEXT_PUBLIC_SITE_URL is also accepted for client-side QR.
# Dev: http://localhost:3000   Prod: https://froq.io
# No trailing slash. Never hardcode domains in code.
APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Cron — required for /api/cron/* routes.
# Generate: openssl rand -hex 32
# Add the same value in Vercel Project Settings → Environment Variables as CRON_SECRET.
# Vercel Cron sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Note: WhatsApp Meta templates register a fixed base URL button
#   https://froq.io/c/{{1}}
# Runtime only sends the dynamic suffix: url_buttons["0"] = customer.publicToken
# Sample values used for Meta approval must never be sent at runtime.

# ─────────────────────────────────────────────────────────────────────────────
# Resend — transactional email (password reset, etc.). Server-only.
# RESEND_FROM_EMAIL must be a verified domain in Resend for production.
# Until your domain is verified, Resend allows: Froq <onboarding@resend.dev>
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Froq <hello@froq.io>

# ─────────────────────────────────────────────────────────────────────────────
# APITxT — OTP delivery (WhatsApp primary via Unified OTP API, SMS fallback)
# Dashboard → Settings → API. Server-only; NEVER expose to the browser.
APITXT_AUTH_KEY=your-apitxt-authkey
APITXT_PROJECT_REF_ID=PROJ_1c54b9ef2a44
APITXT_WHATSAPP_TEMPLATE_NAME=otp
# ISO dialing code for WhatsApp OTP billing (APITxT expects "91", not "IN")
# APITXT_WHATSAPP_COUNTRY=91

# Transactional SMS (customer notifications when WhatsApp is not preferred).
# Required for SMS fallback of stamp/reward/waitlist/reservation alerts.
# APITXT_SMS_SENDER=FROQTX
# APITXT_SMS_PE_ID=your-dlt-principal-entity-id
# APITXT_SMS_ROUTE=4
# APITXT_SMS_TEMPLATE_ID=optional-default-dlt-template-id
# Optional per-template DLT ids:
# APITXT_SMS_TEMPLATE_STAMP_VERIFIED=
# APITXT_SMS_TEMPLATE_REWARD_UNLOCKED=
# APITXT_SMS_TEMPLATE_STAMP_COLLECTED_LAST_WAIT_TIME=
# APITXT_SMS_TEMPLATE_REWARD_READY_WAIT_TIME=
# APITXT_SMS_TEMPLATE_REWARD_REDEEMED=
# APITXT_SMS_TEMPLATE_WAITLIST_CALLED=
# APITXT_SMS_TEMPLATE_RESERVATION_CONFIRMED=

# Country code prefixed to 10-digit Indian numbers before sending/looking up.
OTP_COUNTRY_CODE=91

# Secret used to HMAC-hash OTPs before storing them. Use a long random string.
# Generate with: openssl rand -hex 32
OTP_HASH_SECRET=change-me-to-a-long-random-string

# ─────────────────────────────────────────────────────────────────────────────
# Cashfree Payments — subscription checkout. Dashboard → Developers → API Keys.
# CASHFREE_SECRET_KEY is server-only; NEVER expose it to the browser.
# Use "sandbox" with TEST keys and "production" with live keys.
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key
CASHFREE_ENV=sandbox
NEXT_PUBLIC_CASHFREE_ENV=sandbox
