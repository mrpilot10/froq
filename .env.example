# Supabase — copy this file to .env.local and fill in your project values.
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key (NEVER expose to the browser). Used by trusted server actions
# such as creating a merchant during onboarding. Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the deployed app (used for QR join links). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# APITxT — SMS OTP delivery (Unified OTP API, system default SMS template)
# Dashboard → Settings → API. Server-only; NEVER expose to the browser.
APITXT_AUTH_KEY=your-apitxt-authkey

# Country code prefixed to 10-digit Indian numbers before sending/looking up.
OTP_COUNTRY_CODE=91

# Secret used to HMAC-hash OTPs before storing them. Use a long random string.
# Generate with: openssl rand -hex 32
OTP_HASH_SECRET=change-me-to-a-long-random-string
